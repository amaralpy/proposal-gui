DATABASE_URL=postgresql://usuario:password@localhost:5432/prospect_gui
FLASK_SECRET_KEY=cambiar-por-una-clave-segura

REST_API_BASE_URL=http://localhost:3000
# QUOTATIONS_CALCULATE_URL=http://localhost:3000/api/v1/quotations/calculate
AUDIT_MAX_DISTANCE=0.7

LDAP_ENABLED=true
LDAP_SERVER_URI=ldap://localhost:389
LDAP_BASE_DN=ou=users,dc=example,dc=com
LDAP_USER_FILTER=(sAMAccountName={username})
LDAP_BIND_DN=
LDAP_BIND_PASSWORD=

DEFAULT_ROLE=viewer

LOG_DIR=logs
LOG_LEVEL=INFO
LOG_MAX_BYTES=5242880
LOG_BACKUP_COUNT=10